    <flow id="NS_offpeak_moto_1" type="motorcycle" from="-E7" to="E8" begin="0" end="25200" probability="0.01"/>
    <flow id="NS_offpeak_truck_1" type="truck" from="-E7" to="E8" begin="0" end="25200" probability="0.005"/>
    <flow id="NS_offpeak_delivery_1" type="delivery" from="-E7" to="E8" begin="0" end="25200" probability="0.005"/>
    <flow id="NS_offpeak_bus_1" type="bus" from="-E7" to="E8" begin="0" end="25200" probability="0.002"/>

