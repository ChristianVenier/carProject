<routes>
    <!-- Definizione dei Tipi di Veicoli -->
    <vType id="car" vClass="passenger" length="4.5" maxSpeed="13.89" accel="2.6" decel="4.5" sigma="0.5"/>
    <vType id="motorcycle" vClass="motorcycle" length="2.2" maxSpeed="13.89" accel="4.0" decel="5.0" sigma="0.8"/>
    <vType id="truck" vClass="truck" length="10.0" maxSpeed="11.11" accel="1.5" decel="3.0" sigma="0.3"/>
    <vType id="delivery" vClass="delivery" length="7.0" maxSpeed="12.50" accel="2.0" decel="3.5" sigma="0.4"/>
    <vType id="bus" vClass="bus" length="12.0" maxSpeed="10.00" accel="1.2" decel="2.8" sigma="0.2"/>

    <!-- Flussi di Traffico -->
    <!-- Nord-Sud (Strada Principale) -->
    <!-- Ore di Punta (7:00-13:00, 25200-46800 secondi) -->
    <flow id="NS_peak_car" type="car" from="-E7" to="E8" begin="25200" end="46800" probability="0.05"/>
    <flow id="NS_peak_moto" type="motorcycle" from="-E7" to="E8" begin="25200" end="46800" probability="0.02"/>
    <flow id="NS_peak_truck" type="truck" from="-E7" to="E8" begin="25200" end="46800" probability="0.01"/>
