    <flow id="NS_peak_bus" type="bus" from="-E7" to="E8" begin="25200" end="46800" probability="0.005"/>

    <flow id="SN_peak_car" type="car" from="-E8" to="E7" begin="25200" end="46800" probability="0.05"/>
