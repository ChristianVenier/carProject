    <flow id="EW_offpeak_car_1" type="car" from="-E5" to="E6" begin="0" end="25200" probability="0.015"/>
    <flow id="EW_offpeak_moto_1" type="motorcycle" from="-E5" to="E6" begin="0" end="25200" probability="0.005"/>
